# APP
IS_PROD=false # dev, production

# LOG
LOG_LEVEL="debug" # debug, info, warm, error

# HTTP
HTTP_HOST="0.0.0.0"
HTTP_PORT="8080"
HTTP_READ_TIMEOUT=10 # * time.Second
HTTP_WRITE_TIMEOUT=15 # * time.Second
HTTP_IDLE_TIMEOUT=60 # * time.Second

# DB
DB_MINCONNS=10
DB_MAXCONNS=10
DB_DATABASE="orgstruct"
DB_USERNAME="postgres"
DB_PASSWORD="postgres"
DB_SSLMODE="disable"
# POSTGRES_DB_URL="postgres://postgres:postgres@<name>-postgres:5432/<name>DB?sslmode=disable"
